# ── Firebase (required) ──────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ── Thirdweb ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=

# ── GitHub App ──────────────────────────────────────────────────────────────
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=
NEXT_PUBLIC_GITHUB_APP_SLUG=

# ── Swarm LINK Contracts (Ethereum Sepolia) ─────────────────────────────────
# Populated by contracts/scripts/deploy.ts after deployment
NEXT_PUBLIC_LINK_AGENT_REGISTRY=
NEXT_PUBLIC_LINK_TASK_BOARD=
NEXT_PUBLIC_LINK_ASN_REGISTRY=
NEXT_PUBLIC_LINK_TREASURY=

# ── Platform Keys (SECRET — never expose client-side) ───────────────────────
SEPOLIA_PLATFORM_KEY=
HEDERA_PLATFORM_KEY=

# ── App Domain (canonical production origin for OAuth redirects) ────────
NEXT_PUBLIC_APP_DOMAIN=swarmprotocol.fun

# ── Upstash Redis (rate limiting, nonce replay protection, distributed locks) ─
UPSTASH_REDIS_REST_URL=       # e.g. https://us1-example.upstash.io
UPSTASH_REDIS_REST_TOKEN=     # Bearer token from Upstash console

# ── Session / Admin ─────────────────────────────────────────────────────────
SESSION_SECRET=
PLATFORM_ADMIN_SECRET=
INTERNAL_SERVICE_SECRET=
PLATFORM_ADMIN_WALLETS=
NEXT_PUBLIC_ADMIN_ADDRESS=

# ── OpenClaw (optional — only for workspace integration) ────────────────────
OPENCLAW_DIR=~/.openclaw
OPENCLAW_AGENT=main
WORKSPACE_DIR=
NEXT_PUBLIC_OPENCLAW_WORKSPACE=

# ── E2B Compute (cloud desktop sandboxes) ───────────────────────────────────
E2B_API_KEY=

# ── Azure Compute (primary cloud provider) ──────────────────────────────────
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=






# Text generation — first available key is used (priority: Anthropic > OpenAI > Gemini > fallback templates)
ANTHROPIC_API_KEY=           # Claude claude-sonnet-4-6 for natural prank message writing
OPENAI_API_KEY=              # GPT-4o text + DALL-E 3 images + OpenAI TTS (covers all 3 media types)
GOOGLE_AI_API_KEY=           # Gemini 1.5 Flash (free tier available at aistudio.google.com)

# Image generation — first available key is used (priority: fal.ai > DALL-E > none)
FAL_KEY=                     # fal.ai API key for FLUX image generation (fast, cheap, realistic)
# (OPENAI_API_KEY above also enables DALL-E 3 image generation)

# Voice generation — first available key is used (priority: ElevenLabs > OpenAI TTS > none)
ELEVENLABS_API_KEY=          # ElevenLabs TTS (most realistic voice cloning)
ELEVENLABS_VOICE_ID=         # ElevenLabs voice ID (default: Bella — EXAVITQu4vr4xnSDxMaL)
# (OPENAI_API_KEY above also enables OpenAI TTS with voice "nova")
